{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "nhn-provider": {
            "name": "nhn openai compatible",
            "npm": "@ai-sdk/openai-compatible",
            "models": {
                "nhn-coder": {
                    "name": "nhn-coder"
                },
                "nhn-large:fast": {
                    "name": "nhn-openai-oss-120b"
                },
            },
            "options": {
                "baseURL": "https://chat.nhn.no/api/v1",
            }
        },
        "lmstudio": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "LM Studio (Local)",
            "options": {
                "baseURL": "http://localhost:1234/v1"
            },
            "models": {
                "openai/gpt-oss-20b": {
                    "name": "OpenAI GPT OSS 20b"
                },
                "nvidia/nemotron-3-nano": {
                    "name": "Nemotron 3 nano"
                }
            }
        }
    },
    "model": "qwen/qwen3-coder-next-fp8",
    "agent": {
        "build": {
            "model": "qwen/qwen3-coder-next-fp8",
            "temperature": 0.15,
            "top_p": 0.95,
            "maxSteps": 20,
            "prompt": ".opencode/prompts/build-helm.md",
            "permission": {
                "bash": {
                    "*": "ask",
                    "helm template *": "allow",
                    "helm lint *": "allow",
                    "difft *": "allow",
                    "diff *": "allow",
                    "git diff *": "allow",
                    "git show *": "allow",
                    "git log *": "allow",
                    "git add rendered/before-*": "allow",
                    "mkdir rendered": "allow",
                    "cat *": "allow"
                }
            },
            "permission": {
                "task": {
                    "helm-exec": "allow",
                    "helm-render": "allow",
                    "helm-diff": "allow"
                }
            }
        },
        "plan": {
            "model": "openai-oss/oss-120b",
            "temperature": 0.0,
            "maxSteps": 10,
            "prompt": ".opencode/prompts/plan-helm.md",
            "permission": {
                "edit": {
                    "*": "deny"
                },
                "bash": {
                    "*": "deny"
                }
            }
        }
    }
}
